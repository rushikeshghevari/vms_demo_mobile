# Backend API URL.
# Development: run .\scripts\start-ngrok.ps1 from the repo root - it starts ngrok
# and auto-populates this file with the live HTTPS tunnel URL.
# Production: set this to the Railway backend URL in your EAS build env variables.
EXPO_PUBLIC_API_URL=https://<your-ngrok-subdomain>.ngrok-free.app/api/v1

# Request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=15000

# "development" | "staging" | "production"
EXPO_PUBLIC_APP_ENV=development
