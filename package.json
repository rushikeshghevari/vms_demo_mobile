    "@react-navigation/native-stack": "^7.17.6",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "expo": "~56.0.15",
    "expo-asset": "~56.0.19",
    "expo-constants": "~56.0.20",
    "expo-dev-client": "~56.0.22",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.20",
    "expo-notifications": "~56.0.20",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.21",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.21",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-hook-form": "^7.80.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "0.8.3",
    "react-redux": "^9.3.0",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.15",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:usb": "powershell -ExecutionPolicy Bypass -File ../scripts/start-usb.ps1",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "overrides": {
    "@react-native/jest-preset": "0.85.3",
    "react-test-renderer": "19.2.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/src/test/setupTests.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^immer$": "<rootDir>/node_modules/immer/dist/cjs/index.js",
      "^react-redux$": "<rootDir>/node_modules/react-redux/dist/cjs/index.js"
    }
  }
}
